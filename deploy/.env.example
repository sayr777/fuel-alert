# ============================================================
# Production environment for Yandex Cloud VM
# cp .env.example .env  →  заполнить значения  →  docker compose up -d
# ============================================================

# --- PostgreSQL (внутри Docker на VM) ---
DB_USER=fuelwatch
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=fuelwatch

# --- Redis (внутри Docker на VM) ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- Yandex Object Storage (заменяет MinIO) ---
# Создайте сервисный аккаунт с ролью storage.editor и статический ключ:
# https://console.yandex.cloud → IAM → Сервисные аккаунты
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_ACCESS_KEY=<yc-service-account-key-id>
S3_SECRET_KEY=<yc-service-account-secret-key>
S3_BUCKET=fuel-watch-photos
# Публичный URL бакета (если бакет публичный):
S3_PUBLIC_URL=https://storage.yandexcloud.net/fuel-watch-photos

# --- Домен (используется для CORS) ---
# Пример: https://fuelwatch.example.ru
DOMAIN_ORIGIN=https://YOURDOMAIN.ru

# --- Модерация ---
# Генерировать: openssl rand -hex 32
MODERATOR_TOKEN=CHANGE_ME_random_hex_token

# --- Telegram-бот ---
# Токен от @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# Username бота для кнопки на сайте
VITE_TELEGRAM_BOT_URL=https://t.me/YOUR_BOT_USERNAME
