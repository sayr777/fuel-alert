# Скопируйте в .env и заполните перед запуском (docker compose или локально).
# Один и тот же файл используется backend/, bot/ и docker-compose.yml.

# --- База данных ---
# PostgreSQL + расширение PostGIS. В docker-compose хост "db" резолвится внутри сети контейнеров;
# для локального запуска без Docker используйте localhost.
DATABASE_URL=postgresql+asyncpg://fuelwatch:fuelwatch@localhost:5432/fuelwatch

# --- Redis ---
# Хранит скользящее окно rate-limit (не чаще N обращений в час с одного telegram_id).
REDIS_URL=redis://localhost:6379/0

# --- Объектное хранилище (S3-совместимое, MinIO локально) ---
# Сюда складываются фото обращений; в базе хранятся только ссылки и хэши, не сами файлы.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=fuelwatch
S3_SECRET_KEY=fuelwatch123
S3_BUCKET=fuel-watch-photos
# Публичный URL, по которому фото отдаются наружу (браузеру) — может отличаться от S3_ENDPOINT_URL,
# если MinIO/S3 находится за отдельным публичным доменом/CDN.
S3_PUBLIC_URL=http://localhost:9000/fuel-watch-photos

# --- Модерация ---
# Общий секрет для входа в панель модерации (заголовок X-Moderator-Token).
# ОБЯЗАТЕЛЬНО смените на случайное значение перед реальным использованием —
# значение по умолчанию ниже — только для локальной разработки.
MODERATOR_TOKEN=change-me-moderator-token

# --- Telegram-бот ---
# Токен от @BotFather. Без него bot-контейнер не запустится (профиль "bot" в docker-compose).
BOT_TOKEN=your-telegram-bot-token
# Адрес backend API, который использует бот. Внутри docker-сети — http://api:8000/api/v1.
API_BASE_URL=http://localhost:8000/api/v1

# --- Команды запуска ---
# Docker: docker compose up -d                 (инфраструктура + API + сид демо-данных)
# Docker: docker compose --profile bot up -d   (то же самое + Telegram-бот)
# Локальный сид без Docker: cd backend && python scripts/seed_stations.py
